# Copy to .env and fill in the values before running docker compose up.
# The dev stack (docker-compose.dev.yml) does NOT need this file.

# ── Database ──────────────────────────────────────────────────────────────────
# "db" is the Docker Compose service name — do not change the host.
POSTGRES_DB=knowledge_hoarder
POSTGRES_USER=khoarder
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql+asyncpg://khoarder:change_me@db:5432/knowledge_hoarder

# ── Storage ───────────────────────────────────────────────────────────────────
# Path inside the backend container. Leave as /storage when using Docker Compose.
STORAGE_PATH=/storage

# ── Frontend port (optional, default 80) ─────────────────────────────────────
# FRONTEND_PORT=80

# ── LM Studio ─────────────────────────────────────────────────────────────────
# LM Studio runs on a separate device and exposes an OpenAI-compatible API.
# 1. Start LM Studio → Developer tab → Start server.
# 2. Find the IP:port shown in the server panel (default: 1234).
# 3. Set LLM_BASE_URL to http://<ip>:<port>/v1 (must end with /v1).
# 4. Set LLM_MODEL to the model name shown in LM Studio (copy from "Model" dropdown).
#
# LLM_BASE_URL=http://192.168.1.100:1234/v1
# LLM_MODEL=mistral-7b-instruct-v0.2
# LLM_TIMEOUT=60          # seconds; increase for slow/large models
# LLM_CONTEXT_ENTRIES=5   # entries sent as context per Q&A question
